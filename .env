# OpenAI API Configuration
OPENAI_API_KEY=your_api_key_here
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o
LLM_TEMPERATURE=0.2

# HuggingFace Configuration (if using)
HF_MODEL_ID=mistralai/Mixtral-8x7B-Instruct-v0.1
HF_API_KEY=your_huggingface_api_key_here

# Llama.cpp Configuration (if using locally)
LLAMA_MODEL_PATH=./models/llama-2-13b-chat.gguf
LLAMA_CONTEXT_WINDOW=4096

# WordPress Integration
WP_API_URL=https://your-wordpress-site.com/wp-json/wp/v2
WP_USERNAME=your_username
WP_PASSWORD=your_application_password

# Threads API (Meta)
THREADS_API_KEY=your_threads_api_key

# News API
NEWS_API_KEY=your_news_api_key

# Academic APIs
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Application Configuration
CONFIG_PATH=config/app_config.yaml